# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,exp://localhost:8081
CORS_DELEGATE_TO_PROXY=false

# Frontend
FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
APP_SCHEME=mezon-tutors://

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:6543/mezon-tutors?schema=public

# JWT Configuration
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id-from-console
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-console
GOOGLE_CALENDAR_CALLBACK_URL=http://localhost:4000/api/google-calendar/oauth/callback

# Admin Mezon ID
ADMIN_MEZON_ID=mezon-user-id-for-admin-dm-notifications

# Mezon bot
BOT_ID=mezon-bot-id
BOT_TOKEN=mezon-bot-token

# Mezon app
MEZON_APP_SECRET=mezon-app-secret-1,mezon-app-secret-2

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# R2 image proxy (avatar upload) – same AUTH_KEY as r2-worker's AUTH_KEY_SECRET
R2_IMAGE_PROXY_URL=http://localhost:8788
R2_AUTH_KEY=your-r2-worker-auth-key

SUPABASE_URL=FIXME
SUPABASE_API_KEY=FIXME
SUPABASE_URL_STORAGE_BUCKET=mezon-tutors-dev

# VNPay
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_SECURE_SECRET=your-vnpay-secure-secret
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_TEST_MODE=true

# PayOS
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
# Set true after ngrok is running and PUBLIC_API_URL matches the tunnel URL
PAYOS_AUTO_CONFIRM_WEBHOOK=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
