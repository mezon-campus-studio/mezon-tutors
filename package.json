{
  "name": "mezon-tutors",
  "private": true,
  "workspaces": [
    "./apps/*",
    "./packages/*"
  ],
  "scripts": {
    "dev": "yarn build && turbo run dev",
    "watch": "ultra -r --no-pretty --concurrency 400 watch",
    "vercel:install": "yarn set version 3.5 && yarn install",
    "web": "yarn build && cd apps/web && yarn dev",
    "web:prod": "yarn workspace @mezon-tutors/web build",
    "web:prod:serve": "yarn workspace @mezon-tutors/web serve",
    "vercel:web": "cd \"$(git rev-parse --show-toplevel)\" && npx vercel",
    "api": "yarn build && cd apps/api && yarn dev",
    "api:prod": "yarn workspace @mezon-tutors/api build",
    "db:reset": "yarn workspace @mezon-tutors/db prisma:reset",
    "db:migrate": "yarn workspace @mezon-tutors/db prisma:migrate",
    "db:seed": "yarn workspace @mezon-tutors/db seed",
    "r2": "cd apps/r2-worker && yarn dev",
    "postinstall": "node scripts/postinstall.js",
    "build": "turbo build --filter=!@mezon-tutors/web",
    "format": "turbo format",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node scripts/clean-cache.ts",
    "prepare": "husky"
  },
  "resolutions": {
    "react": "^19.2.4",
    "react-dom": "19.2.4",
    "react-refresh": "^0.14.0",
    "zod": "^4.1.12",
    "effect": "3.20.0",
    "tar": "7.5.11",
    "undici": "6.24.0",
    "file-type": "21.3.2",
    "js-yaml": "4.1.1",
    "lodash": "4.17.23",
    "multer": "2.1.1",
    "minimatch": "10.2.3",
    "ajv": "8.18.0",
    "@tootallnate/once": "3.0.1",
    "brace-expansion": "5.0.5",
    "picomatch": "4.0.4",
    "prompts": "2.4.2",
    "node-forge": "1.4.0",
    "yaml": "2.8.3",
    "smol-toml": "1.6.1",
    "srvx": "0.11.13",
    "next": "16.2.3",
    "postcss": "^8.5.10",
    "path-to-regexp": "^8.2.0",
    "@nestjs/common": "^11.1.18"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.6",
    "@hookform/resolvers": "^5.2.2",
    "check-dependency-version-consistency": "^4.1.0",
    "husky": "^9.1.6",
    "react-ga4": "^3.0.1",
    "react-hook-form": "^7.71.1",
    "turbo": "^1.13.4",
    "typescript": "~5.8.3",
    "ultra-runner": "^3.10.5",
    "vitest": "^2.1.1",
    "zod": "^4.1.12"
  },
  "engines": {
    "node": ">=22",
    "npm": "10.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.3",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "yarn@4.11.0"
}
