generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
  CTV
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ETrialLessonStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ProfessionalDocumentStatus {
  NEW
  PENDING
  APPROVED
  REJECTED
}

enum ProfessionalDocumentType {
  DEGREE
  CERTIFICATE
  CV
  OTHER
}

enum IdentityVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EDayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum EPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum EWalletTransactionType {
  BOOKING_PAYMENT
  RELEASE
  WITHDRAWAL
  REFUND
  PLATFORM_FEE
}

enum EWalletTransactionDirection {
  CREDIT
  DEBIT
}

enum EWithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum ECurrency {
  USD
  VND
  PHP
}

enum ENotificationType {
  BOOKING
  PAYMENT
  SYSTEM
  LESSON_STARTING_SOON
}

enum ESubscriptionEnrollmentStatus {
  PENDING_PAYMENT
  ACTIVE
  CANCELLED
}

enum ESubscriptionLessonSlotStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ELessonSettlementKind {
  TRIAL_LESSON
  SUBSCRIPTION_SLOT
}

enum ELessonSettlementJobStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ELessonChangeAction {
  CANCEL
  RESCHEDULE
}

enum ELessonChangeLessonType {
  TRIAL
  SUBSCRIPTION
}

enum ELessonChangeInitiatorRole {
  STUDENT
  TUTOR
  SYSTEM
}

enum ELessonComplaintStatus {
  PENDING
  TUTOR_REVIEW_REQUESTED
  TUTOR_CONFIRMED
  TUTOR_REJECTED
  APPROVED
  REJECTED
}

/// Application users table mapped to `users`
model User {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mezonUserId            String                  @unique @map("mezon_user_id")
  username               String
  avatar                 String
  role                   Role                    @default(STUDENT)
  email                  String?
  timezone               String                  @default("UTC")
  createdAt              DateTime                @default(now()) @map("created_at")
  tutorProfile           TutorProfile?
  trialLessonBookings    TrialLessonBooking[]
  subscriptionEnrollments SubscriptionEnrollment[]
  tutorReviews           TutorReview[]           @relation("TutorReviewAuthor")
  senderDmChannels       UserDmChannel[]         @relation("UserDmChannelSender")
  recipientDmChannels    UserDmChannel[]         @relation("UserDmChannelRecipient")
  refreshTokens          RefreshToken[]
  wallet                 Wallet?
  withdrawals            Withdrawal[]
  notificationRecipients NotificationRecipient[]
  cancelRescheduleReasonsAsStudent CancelRescheduleReason[] @relation("CancelRescheduleStudent")
  cancelRescheduleReasonsInitiated CancelRescheduleReason[] @relation("CancelRescheduleInitiator")
  lessonComplaintsAsStudent        LessonComplaint[]        @relation("LessonComplaintStudent")
  lessonComplaintsReviewed         LessonComplaint[]        @relation("LessonComplaintReviewer")
  appSettingsUpdates               AppSettings[]            @relation("AppSettingsUpdatedBy")
  createdEvents                    Event[]                  @relation("EventCreatedBy")
  reviewedEvents                   Event[]                  @relation("EventReviewedBy")
  googleCalendarConnection         GoogleCalendarConnection?
  vocabularyWords                  VocabularyWord[]
  groupsLed                        Group[]                 @relation("GroupLeader")
  groupMemberships                 GroupMember[]
  savedTutors                      SavedTutor[]
  blogPosts                        BlogPost[]                @relation("BlogPostAuthor")
  blogReviewedPosts                BlogPost[]                @relation("BlogPostReviewedBy")
  blogPostComments                 BlogPostComment[]         @relation("BlogPostCommentAuthor")
  blogPostUpvotes                  BlogPostUpvote[]                 @relation("BlogPostUpvoteUser")
  blogPostCommentUpvotes           BlogPostCommentUpvote[]          @relation("BlogPostCommentUpvoteUser")
  learningLogs                     LearningLog[]
  communityPosts                   CommunityPost[]                  @relation("CommunityPostAuthor")
  communityComments                CommunityComment[]               @relation("CommunityCommentAuthor")
  communityPostUpvotes             CommunityPostUpvote[]            @relation("CommunityPostUpvoteUser")
  communityCommentUpvotes          CommunityCommentUpvote[]         @relation("CommunityCommentUpvoteUser")
  communityFollowing              CommunityFollow[]              @relation("CommunityFollowSource")
  communityFollowers              CommunityFollow[]              @relation("CommunityFollowTarget")
  communityExerciseSubmissions     CommunityExerciseSubmission[]
  communityReports                 CommunityReport[]                @relation("CommunityReporter")
  communityReportsReviewed         CommunityReport[]                @relation("CommunityReportReviewer")

  @@map("users")
}

enum VocabularyWordStatus {
  ready
  learning
  learned
}

/// Student vocabulary words for practice
model VocabularyWord {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String               @map("student_id") @db.Uuid
  word         String
  phonetic     String?
  partOfSpeech String               @map("part_of_speech")
  definition   String               @db.Text
  example      String?              @db.Text
  audioUrl     String?              @map("audio_url")
  status       VocabularyWordStatus @default(ready)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  learningLogs LearningLog[]

  @@unique([studentId, word, definition])
  @@index([studentId, word])
  @@map("vocabulary_words")
}

model GoogleCalendarConnection {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  googleEmail    String    @map("google_email")
  accessToken    String    @map("access_token") @db.Text
  refreshToken   String?   @map("refresh_token") @db.Text
  tokenExpiresAt DateTime? @map("token_expires_at")
  calendarId     String?   @map("calendar_id")
  lastSyncedAt   DateTime? @map("last_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_connections")
}

model Notification {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  content           String                  @db.Text
  type              ENotificationType
  i18nKey           String?                 @map("i18n_key")
  i18nParams        Json?                   @map("i18n_params")
  dedupeKey         String?                 @unique @map("dedupe_key")
  metadata          Json?
  createdAt         DateTime                @default(now()) @map("created_at")
  recipients        NotificationRecipient[]

  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId String       @map("notification_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@index([userId, isRead])
  @@map("notification_recipients")
}

/// Tutor profile (1:1 with User)
model TutorProfile {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  firstName          String             @map("first_name")
  lastName           String             @map("last_name")
  videoUrl           String             @default("") @map("video_url")
  country            String
  phone              String
  email              String
  subject            String             @default("")
  introduce          String             @default("")
  experience         String             @default("")
  headline           String             @default("")
  isProfessional     Boolean            @default(false) @map("is_professional")
  activeStatus       Boolean            @default(true) @map("active_status")
  verificationStatus VerificationStatus @map("verification_status")
  totalLessonsTaught Int                @default(0) @map("total_lessons_taught")
  totalStudents      Int                @default(0) @map("total_students")
  ratingCount        Int                @default(0) @map("rating_count")
  ratingAverage      Decimal            @default(0) @map("rating_average") @db.Decimal(3, 2)
  mezonClanId        String?         
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  languages           TutorLanguage[]
  availability        TutorAvailability[]
  trialLessonBookings TrialLessonBooking[]
  reviews             TutorReview[]
  trialLessonPrice    TrialLessonPrice?
  subscriptionEnrollments SubscriptionEnrollment[]
  cancelRescheduleReasons CancelRescheduleReason[]
  lessonComplaints        LessonComplaint[]

  adminNotes            TutorAdminNote[]
  professionalDocuments ProfessionalDocument[]
  identityVerification  IdentityVerification?
  setupChecklist        TutorSetupChecklist?
  savedBy               SavedTutor[]

  @@index([verificationStatus, subject], map: "tutor_profiles_verif_subject_idx")
  @@index([verificationStatus, country], map: "tutor_profiles_verif_country_idx")
  @@index([verificationStatus, ratingAverage, ratingCount], map: "tutor_profiles_verif_rating_idx")
  @@map("tutor_profiles")
}

model SavedTutor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  tutorId   String   @map("tutor_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  student User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor   TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([studentId, tutorId])
  @@index([studentId, createdAt])
  @@index([tutorId])
  @@map("saved_tutors")
}

model TutorSetupChecklist {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId                 String   @unique @map("tutor_id") @db.Uuid
  createMezonClanComplete Boolean  @default(false) @map("create_mezon_clan_complete")
  setupMezonClanComplete  Boolean  @default(false) @map("setup_mezon_clan_complete")
  channelAppsComplete     Boolean  @default(false) @map("channel_apps_complete")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("tutor_setup_checklists")
}

model TrialLessonPrice {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId       String      @unique @map("tutor_id") @db.Uuid
  baseCurrency  ECurrency   @default(VND) @map("type")
  usd           Decimal     @db.Decimal(18, 6)
  vnd           BigInt      @db.BigInt
  php           Decimal     @db.Decimal(18, 6)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tutor     TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("trial_lesson_prices")
}

model SubscriptionEnrollment {
  id               String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String                         @map("student_id") @db.Uuid
  tutorId          String                         @map("tutor_id") @db.Uuid
  lessonsPerWeek   Int                            @map("lessons_per_week")
  status           ESubscriptionEnrollmentStatus  @default(PENDING_PAYMENT)
  weeklySlots      Json                           @map("weekly_slots")
  currency         ECurrency?                     @map("currency")
  grossAmount      BigInt                         @default(0) @map("gross_amount")
  platformFee      BigInt                         @default(0) @map("platform_fee")
  tutorAmount      BigInt                         @default(0) @map("tutor_amount")
  deductAmount     BigInt                         @default(0) @map("deduct_amount")
  paymentStatus    EPaymentStatus                 @default(PENDING) @map("payment_status")
  paymentRef       String?                        @unique @map("payment_ref") @db.VarChar(50)
  paymentUrl       String?                        @map("payment_url")
  paidAt           DateTime?                      @map("paid_at")
  failedAt         DateTime?                      @map("failed_at")
  createdAt        DateTime                       @default(now()) @map("created_at")
  updatedAt        DateTime                       @updatedAt @map("updated_at")
 
  student             User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor               TutorProfile      @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  walletTransactions  Transaction[]
  cancelRescheduleReasons CancelRescheduleReason[]
  lessonComplaints    LessonComplaint[]
  groupId             String?           @map("group_id") @db.Uuid
  memberCount         Int?              @map("member_count")
  groupDiscountRate   Decimal?          @map("group_discount_rate") @db.Decimal(4, 2)
  group               Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([studentId, tutorId])
  @@index([paymentRef])
  @@map("subscription_enrollments")
}

/// Reviews from students for tutors
model TutorReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId    String   @map("tutor_id") @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  rating     Int
  comment    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tutor    TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  reviewer User         @relation("TutorReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, tutorId])
  @@index([tutorId, createdAt])
  @@index([reviewerId])
  @@map("tutor_reviews")
}

/// Tutor admin notes
model TutorAdminNote {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId      String   @map("tutor_id") @db.Uuid
  reviewerId   String   @map("reviewer_id")
  reviewerName String   @map("reviewer_name")
  content      String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("tutor_admin_notes")
}

/// Professional documents for tutors
model ProfessionalDocument {
  id             String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId        String                     @map("tutor_id") @db.Uuid
  name           String
  institution    String?
  type           ProfessionalDocumentType
  status         ProfessionalDocumentStatus @default(PENDING)
  uploadedAt     DateTime                   @default(now()) @map("uploaded_at")
  specialization String?
  yearOfComplete Int?                       @map("year_of_complete")
  fileKey        String                     @map("file_key")
  reviewedAt     DateTime?                  @map("reviewed_at")

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("professional_documents")
}

/// Identity verification record
model IdentityVerification {
  id           String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId      String                     @unique @map("tutor_id") @db.Uuid
  status       IdentityVerificationStatus @default(PENDING)
  nameMatch    Boolean                    @default(false) @map("name_match")
  notExpired   Boolean                    @default(false) @map("not_expired")
  photoClarity Boolean                    @default(false) @map("photo_clarity")
  uploadedAt   DateTime                   @default(now()) @map("uploaded_at")
  fileKey      String                     @map("file_key")
  reviewedAt   DateTime?                  @map("reviewed_at")

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("identity_verification")
}

/// Tutor spoken languages
model TutorLanguage {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId      String @map("tutor_id") @db.Uuid
  languageCode String @map("language_code")
  proficiency  String

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([tutorId, languageCode])
  @@map("tutor_language")
}

/// Tutor weekly availability slots
model TutorAvailability {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId             String               @map("tutor_id") @db.Uuid
  dayOfWeek           Int                  @map("day_of_week")
  startTime           String               @map("start_time")
  endTime             String               @map("end_time")
  isActive            Boolean              @default(true) @map("is_active")
  tutor               TutorProfile         @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([tutorId, dayOfWeek, startTime, endTime])
  @@map("tutor_availability")
}

/// Student booked/completed lesson sessions
model TrialLessonBooking {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutorId             String             @map("tutor_id") @db.Uuid
  studentId           String             @map("student_id") @db.Uuid
  startAt             DateTime           @map("start_at")
  durationMinutes     Int                @map("duration_minutes")
  status              ETrialLessonStatus @default(PENDING)
  grossAmount         BigInt              @map("gross_amount")
  platformFee         BigInt              @map("platform_fee")
  tutorAmount         BigInt              @map("tutor_amount")
  deductAmount        BigInt              @default(0) @map("deduct_amount")
  currency            ECurrency           @map("currency")
  paymentStatus    EPaymentStatus  @default(PENDING) @map("payment_status")
  idempotencyKey   String?         @unique @map("idempotency_key")
  paymentRef       String?         @map("payment_ref") @db.VarChar(50) @unique
  paymentUrl       String?         @map("payment_url")
  paidAt           DateTime?       @map("paid_at")
  failedAt         DateTime?       @map("failed_at")
  refundedAt       DateTime?       @map("refunded_at")
  cancelReason     String?            @map("cancel_reason")
  cancelMessage    String?            @map("cancel_message") @db.Text
  
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  tutor   TutorProfile         @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  student User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  walletTransactions Transaction[]
  cancelRescheduleReasons CancelRescheduleReason[]
  lessonComplaint       LessonComplaint?

  @@index([paymentRef])
  @@index([studentId])
  @@index([tutorId])
  @@index([tutorId, startAt])
  @@map("trial_lesson_booking")
}

/// Audit log for lesson cancel / reschedule requests (tutor or student).
model CancelRescheduleReason {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId                 String                   @map("student_id") @db.Uuid
  tutorId                   String                   @map("tutor_id") @db.Uuid
  initiatedByUserId         String                   @map("initiated_by_user_id") @db.Uuid
  initiatedByRole           ELessonChangeInitiatorRole @map("initiated_by_role")
  action                    ELessonChangeAction
  lessonType                ELessonChangeLessonType  @map("lesson_type")
  reason                    String
  message                   String?                  @db.Text
  trialLessonBookingId      String?                  @map("trial_lesson_booking_id") @db.Uuid
  subscriptionEnrollmentId  String?                  @map("subscription_enrollment_id") @db.Uuid
  subscriptionSlotIndex     Int?                     @map("subscription_slot_index")
  originalStartAt           DateTime                 @map("original_start_at")
  originalDurationMinutes   Int                      @map("original_duration_minutes")
  createdAt                 DateTime                 @default(now()) @map("created_at")

  student              User                    @relation("CancelRescheduleStudent", fields: [studentId], references: [id], onDelete: Cascade)
  tutor                TutorProfile            @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  initiatedBy          User                    @relation("CancelRescheduleInitiator", fields: [initiatedByUserId], references: [id], onDelete: Cascade)
  trialLessonBooking   TrialLessonBooking?     @relation(fields: [trialLessonBookingId], references: [id], onDelete: SetNull)
  subscriptionEnrollment SubscriptionEnrollment? @relation(fields: [subscriptionEnrollmentId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([tutorId, createdAt])
  @@index([trialLessonBookingId])
  @@index([subscriptionEnrollmentId, subscriptionSlotIndex, originalStartAt])
  @@map("cancel_reschedule_reason")
}

/// Student complaint about a completed lesson; admin may approve for wallet refund.
model LessonComplaint {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId                String                   @map("student_id") @db.Uuid
  tutorId                  String                   @map("tutor_id") @db.Uuid
  lessonType               ELessonChangeLessonType  @map("lesson_type")
  reason                   String
  message                  String?                  @db.Text
  attachmentUrls           Json?                    @default("[]") @map("attachment_urls")
  status                   ELessonComplaintStatus   @default(PENDING)
  trialLessonBookingId     String?                  @unique @map("trial_lesson_booking_id") @db.Uuid
  subscriptionEnrollmentId String?                  @map("subscription_enrollment_id") @db.Uuid
  subscriptionSlotIndex    Int?                     @map("subscription_slot_index")
  lessonStartAt            DateTime                 @map("lesson_start_at")
  lessonDurationMinutes    Int                      @map("lesson_duration_minutes")
  reviewedByUserId         String?                  @map("reviewed_by_user_id") @db.Uuid
  adminNote                String?                  @map("admin_note") @db.Text
  tutorNote                String?                  @map("tutor_note") @db.Text
  reviewedAt               DateTime?                @map("reviewed_at")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  student                User                    @relation("LessonComplaintStudent", fields: [studentId], references: [id], onDelete: Cascade)
  tutor                  TutorProfile            @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  trialLessonBooking     TrialLessonBooking?     @relation(fields: [trialLessonBookingId], references: [id], onDelete: SetNull)
  subscriptionEnrollment SubscriptionEnrollment? @relation(fields: [subscriptionEnrollmentId], references: [id], onDelete: SetNull)
  reviewedBy             User?                   @relation("LessonComplaintReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([subscriptionEnrollmentId, subscriptionSlotIndex, lessonStartAt])
  @@index([status, createdAt])
  @@index([studentId, createdAt])
  @@index([tutorId, createdAt])
  @@index([tutorId, status])
  @@map("lesson_complaints")
}

model UserDmChannel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  recipientId String   @map("recipient_id") @db.Uuid
  channelId   String   @unique @map("channel_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sender    User @relation("UserDmChannelSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("UserDmChannelRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([senderId, recipientId])
  @@index([senderId])
  @@index([recipientId])
  @@map("user_dm_channels")
}

/// Refresh token for session management
model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @map("token")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Wallet {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  balance            BigInt   @default(0)
  pendingBalance     BigInt   @default(0)
  pendingWithdrawal  BigInt   @default(0)
  totalEarned        BigInt   @default(0)
  totalWithdrawn     BigInt   @default(0)
  payoutBankName          String?  @map("payout_bank_name") @db.VarChar(100)
  payoutBankAccountNumber String?  @map("payout_bank_account_number") @db.VarChar(50)
  payoutBankAccountName   String?  @map("payout_bank_account_name") @db.VarChar(255)
